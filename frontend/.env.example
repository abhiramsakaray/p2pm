# thirdweb Client ID (thirdweb.com/dashboard → project → Settings → Client ID).
# Account Abstraction is enabled by default on testnet with a valid Client ID, so
# merchant transactions are gasless on Base Sepolia. Public value, but restrict it
# to your domain(s) in the dashboard.
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=

# The app runs live on Base Sepolia (the p2p.me protocol's testnet).
NEXT_PUBLIC_CHAIN=baseSepolia
NEXT_PUBLIC_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployed MerchantTerminalIntegrator + its price client
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_CLIENT_ADDRESS=

# p2p.me protocol addresses on Base Sepolia
NEXT_PUBLIC_DIAMOND_ADDRESS=0xeb0BB8E3c014D915D9B2df03aBB130a1Fb44beb9
NEXT_PUBLIC_USDC_ADDRESS=0x4095fE4f1E636f11A95820BA2bB87F335Bd1040d

# Subgraph for automatic INR circle selection
NEXT_PUBLIC_SUBGRAPH_URL=https://api.studio.thegraph.com/query/1745491/event-indexer/v0.0.6

# Admin dashboard (server-only — never expose in NEXT_PUBLIC_*)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=random-secret-string
# Private key of the MerchantTerminalIntegrator contract owner (for freeze/unfreeze txs)
ADMIN_PRIVATE_KEY=
# Set to true to mock admin merchant reads + freeze/unfreeze (no chain / no private key)
NEXT_PUBLIC_ADMIN_MOCK=false
